---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import Testimonials from "../components/Testimonials.astro";
import BeforeAfterSlider from "../components/BeforeAfterSlider.astro";

const PRICE = "97";
const PRICE_ORIGINAL = "197";
const CTA_URL = "https://buy.stripe.com/4gM6oz5c28Rq35x5Wybsc00";

// EDIT: mets ton vrai compte Instagram (canal DM pour les hésitants)
const INSTAGRAM_URL = "https://instagram.com/glowupbymehdi";

// VSL hébergée sur Bunny Stream — iframe intégrée directement dans le hero.

const STICKY_CTA = false;

const TESTIMONIALS = [
  {
    name: "Camélia",
    age: "20 ans",
    profile: "Peau grasse · Acné hormonal sur menton + joues",
    duration: "90 jours de protocole",
    avant: ["/camelia-avant-joues.png", "/camelia-avant-menton.png"],
    apres: ["/camelia-apres-joues.png", "/camelia-apres-menton.png"],
  },
  {
    name: "Georges",
    age: "21 ans",
    profile: "Peau grasse · Comédons + Acné",
    duration: "70 jours de protocole",
    avant: ["/georges-avant.png"],
    apres: ["/georges-apres.png"],
  },
  {
    name: "Nathan",
    age: "19 ans",
    profile: "Peau grasse · Acné inflammatoire générale",
    duration: "90 jours de protocole",
    avant: ["/nathan-avant.png"],
    apres: ["/nathan-apres.png"],
  },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Un protocole acné personnalisé, suivi par un coach pendant 90 jours. Fini les produits au hasard." />
    <title>Protocole Clear · Ta peau nette en 90 jours</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <!-- Open Graph (aperçus WhatsApp / Instagram / Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://protocole-clear.com/" />
    <meta property="og:title" content="Protocole Clear · Ta peau nette en 90 jours" />
    <meta property="og:description" content="Un protocole acné construit pour ta peau, suivi par un coach pendant 90 jours. Bilan peau + routine sur mesure + ajustements inclus." />
    <meta property="og:image" content="https://protocole-clear.com/icon-512.png" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Protocole Clear" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Protocole Clear · Ta peau nette en 90 jours" />
    <meta name="twitter:description" content="Un protocole acné construit pour ta peau, suivi par un coach pendant 90 jours." />
    <meta name="twitter:image" content="https://protocole-clear.com/icon-512.png" />

    <!-- Microsoft Clarity — heatmaps de scroll + session replays -->
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x5kf9doj5x");
    </script>
  </head>

  <body>

    <!-- ─── NAVBAR ──────────────────────────────────────────────────────────── -->
    <nav class="navbar fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-3">
      <div class="flex items-center gap-2.5">
        <img src="/logo_clear.png" alt="Protocole Clear" width="44" height="44" style="border-radius:50%;" />
        <span class="hidden sm:inline font-display text-lg font-semibold tracking-tight" style="color:oklch(0.22 0.03 40)">
          Protocole Clear
        </span>
      </div>
      <a href={CTA_URL} data-cta="navbar" class="btn-primary flex min-h-11 items-center rounded-full px-5 text-sm font-semibold">
        Je commence →
      </a>
    </nav>

    <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
    <section data-section="hero" class="hero-section relative md:min-h-screen flex flex-col items-center px-4 pt-20 md:pt-20 pb-8 md:pb-6 text-center overflow-hidden">

      <!-- Animated blobs -->
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>

      <div class="flex-1 flex flex-col items-center justify-start md:justify-center w-full gap-4 md:gap-6 pt-2 md:pt-0">

        <!-- Headline -->
        <h1 class="hero-title text-balance max-w-3xl text-[2rem] font-bold leading-[1.12] sm:text-5xl md:text-5xl lg:text-7xl">
          Tu te trouves moche<br class="sm:hidden" /> à cause de ta peau.<br />
          <span class="text-gradient">On change ça.</span>
        </h1>

        <!-- Sous-ligne -->
        <p class="text-base italic max-w-sm" style="color:oklch(0.5 0.03 45)">
          Dans 90 jours, tu te lèves sans redouter le miroir.
        </p>

        <!-- VSL Bunny Stream -->
        <div class="hero-proof w-full max-w-lg md:max-w-xl lg:max-w-2xl mx-auto">
          <div class="vsl-wrapper rounded-3xl overflow-hidden" style="position:relative;padding-top:56.25%">
            <iframe
              src="https://iframe.mediadelivery.net/embed/664092/02e31b9c-375e-423c-8074-850966638aae?autoplay=true&loop=false&muted=false&preload=true&responsive=true"
              loading="eager"
              style="position:absolute;top:0;left:0;width:100%;height:100%;border:0"
              allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>

        <!-- CTA + urgence sous la vidéo -->
        <div class="hero-cta flex flex-col items-center gap-3 w-full">
          <a href={CTA_URL} data-cta="hero" class="btn-primary rounded-full px-8 py-4 text-base font-bold w-full sm:w-auto" style="min-height:56px;display:flex;align-items:center;justify-content:center;max-width:360px">
            Je veux changer ça →
          </a>
          <p class="text-sm text-center" style="color:oklch(0.45 0.03 45)">⏳ Suivi individuel. Places restreintes.</p>
        </div>

      </div>

    </section>

    <!-- ─── BÉNÉFICES ───────────────────────────────────────────────────────────── -->
    <section data-section="benefices" class="px-6 py-16" style="background:oklch(0.985 0.012 75)">
      <div class="max-w-xl mx-auto space-y-10">
        {[
          { title: "Tu n'as plus peur d'une photo.", desc: "Fini de te préparer mentalement avant de sortir ou d'éviter les lumières." },
          { title: "Fini l'angoisse du miroir le matin.", desc: "Tu arrêtes de scruter chaque bouton en te levant. Ce moment d'angoisse, c'est derrière toi." },
          { title: "Le regard des autres ne te définit plus.", desc: "Ta peau n'est plus la première chose à laquelle tu penses quand quelqu'un te regarde." },
          { title: "Chaque produit a un rôle précis.", desc: "Fini les achats au hasard. Le protocole est construit pour ta peau, pas copié d'une vidéo." },
        ].map((b) => (
          <div class="flex items-start gap-4" data-reveal>
            <span class="mt-1 shrink-0 text-xl" style="color:oklch(0.66 0.14 45)">✓</span>
            <div>
              <p class="text-xl font-bold leading-snug" style="color:oklch(0.22 0.03 40)">{b.title}</p>
              <p class="text-base mt-1" style="color:oklch(0.5 0.03 45)">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── AVANT / APRÈS — slider Mehdi ────────────────────────────────────── -->
    <section data-section="avant-apres" class="py-16 px-6" style="background:oklch(0.965 0.025 75)">
      <div class="max-w-xl mx-auto text-center">
        <p class="eyebrow mb-3">Résultat réel</p>
        <h2 class="text-2xl font-bold mb-8" style="color:oklch(0.22 0.03 40)">Ma transformation en 90 jours.</h2>
        <BeforeAfterSlider
          beforeSrc="/avant.jpg"
          afterSrc="/apres.jpg"
          beforeAlt="Mehdi — avant le protocole"
          afterAlt="Mehdi — après 90 jours"
          initialPosition={42}
        />
        <p class="mt-5 text-sm italic" style="color:oklch(0.5 0.03 45)">Mehdi ZA · Peau grasse à tendance acnéique</p>
      </div>
    </section>

    <!-- ─── WAVE (crème doux → crème clair) ──────────────────────────────────── -->
    <div class="wave-divider" style="background:oklch(0.965 0.025 75)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C480,60 960,0 1440,40 L1440,60 L0,60 Z" fill="oklch(0.985 0.012 75)" />
      </svg>
    </div>

    <!-- ─── TÉMOIGNAGES (carousel) ────────────────────────────────────────────── -->
    <div data-section="temoignages" style="background:oklch(0.985 0.012 75)">
      <Testimonials testimonials={TESTIMONIALS} />
    </div>

    <!-- ─── WAVE (crème → crème : FAQ garde le même fond) ────────────────────── -->
    <div class="wave-divider" style="background:oklch(0.985 0.012 75)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 C360,60 1080,0 1440,40 L1440,60 L0,60 Z" fill="oklch(0.965 0.025 75)" />
      </svg>
    </div>

    <!-- ─── FAQ ──────────────────────────────────────────────────────────────── -->
    <section data-section="faq" class="py-16 px-6" style="background:oklch(0.965 0.025 75)" data-reveal>
      <div class="max-w-2xl mx-auto">
        <p class="eyebrow text-center">Questions fréquentes</p>
        <h2 class="text-3xl font-bold text-center mb-16 md:text-4xl" style="color:oklch(0.22 0.03 40)">
          Je sais que t'as des questions.
        </h2>
        <div class="space-y-4">
          {[
            { q: "Est-ce que ça marche vraiment ?", a: "Les témoignages sur cette page sont réels, avec leurs photos avant/après. Ce n'est pas une méthode universelle : elle est construite sur ton profil peau spécifique, ajustée chaque semaine. Les premières améliorations apparaissent généralement entre 8 et 12 semaines." },
            { q: "Et si ça ne marche pas pour moi ?", a: "Si tu as suivi le protocole sérieusement pendant 90 jours, complété tes suivis et envoyé tes photos, mais qu'aucune évolution positive n'est visible, je prolonge l'accompagnement 30 jours sans frais. Et si ta situation nécessite un avis médical, je te le dis clairement plutôt que de te faire perdre ton temps." },
            { q: "C'est quoi la différence avec une routine trouvée sur TikTok ?", a: "Une routine TikTok est copiée-collée sans tenir compte de ton type de peau, de ton type d'acné, de tes produits actuels, ni de ta réaction réelle. Ici, chaque produit est sélectionné pour toi, et la routine est ajustée chaque semaine selon tes métriques." },
            { q: "Je dois acheter de nouveaux produits en plus ?", a: "Oui, les produits ne sont pas inclus dans les 97€. Ils sont sélectionnés selon ton profil et ton budget existant : compte entre 40 et 80€ pour la routine complète, et ces produits durent plusieurs mois. Bien moins que ce que coûtent 3 mois d'essais au hasard en pharmacie." },
            { q: "Combien de temps ça prend par jour ?", a: "La routine prend 5 à 10 minutes matin et soir. Les suivis hebdomadaires dans l'app prennent 5 minutes. Le reste, c'est moi qui travaille." },
            { q: "Est-ce que tu es dermatologue ?", a: "Non. Je ne suis pas dermatologue et je ne remplace pas un avis médical. Je ne diagnostique pas de maladie et je ne modifie jamais un traitement prescrit. Mon rôle : optimiser ta routine cosmétique, identifier les associations irritantes, et suivre méthodiquement la réaction de ta peau. Si ta situation nécessite un dermatologue, je te le dirai." },
            { q: `Pourquoi ${PRICE}€ et pas plus cher ?`, a: `Le prix couvre 90 jours de suivi individuel, l'accès à vie à l'application, le bilan initial et tous les ajustements de routine. Pour comparaison : 3 mois d'essais de produits au hasard en pharmacie coûtent facilement 300€ sans résultat garanti.` },
            { q: "C'est quoi exactement Protocole Clear ?", a: "Un protocole acné en 3 étapes : un bilan peau complet, une routine matin/soir construite pour ton profil exact, et 90 jours de suivi coach avec ajustements inclus. Tout centralisé dans une application web, sans téléchargement." },
          ].map((item) => (
            <details class="faq-item group rounded-2xl border overflow-hidden" style="border-color:oklch(0.91 0.02 65)">
              <summary class="flex items-center justify-between cursor-pointer px-6 py-5 font-semibold select-none list-none" style="color:oklch(0.22 0.03 40)">
                {item.q}
                <span class="faq-arrow ml-4 flex h-8 w-8 shrink-0 items-center justify-center rounded-full transition-transform group-open:rotate-180" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </span>
              </summary>
              <div class="px-6 pb-5 text-sm leading-relaxed" style="color:oklch(0.5 0.03 45)">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── WAVE (crème → sombre) ────────────────────────────────────────────── -->
    <div class="wave-divider" style="background:oklch(0.965 0.025 75)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,25 C420,60 1020,0 1440,35 L1440,60 L0,60 Z" fill="oklch(0.22 0.03 40)" />
      </svg>
    </div>

    <!-- ─── CTA FINAL (sombre — miroir de la pricing card) ───────────────────── -->
    <section data-section="cta_final" class="final-cta relative overflow-hidden py-20 px-6 text-center" style="background:oklch(0.22 0.03 40)" data-reveal>
      <div class="relative z-10 max-w-2xl mx-auto">
        <h2 class="text-4xl font-bold mb-6 md:text-6xl text-balance" style="color:oklch(0.99 0.01 80)">
          Arrête de subir<br />
          <span class="text-gradient">le regard des autres.</span>
        </h2>
        <p class="text-lg leading-relaxed mb-10 max-w-lg mx-auto" style="color:oklch(0.72 0.03 60)">
          Commence un protocole construit pour ta peau, suivi par quelqu'un qui comprend ce que tu traverses.
        </p>
        <a href={CTA_URL} data-cta="final" class="btn-primary inline-block rounded-full px-10 py-5 text-lg font-bold mb-4">
          Je commence →
        </a>
        <p class="text-sm" style="color:oklch(0.72 0.03 60)">
          Bilan en 10 min · Première routine sous 48h · Sans abonnement
        </p>
      </div>
    </section>

    <Analytics />

    <!-- ─── STICKY CTA MOBILE (apparaît après l'offre, mobile uniquement) ────── -->
    {STICKY_CTA && (
      <div id="sticky-cta" class="sticky-cta fixed bottom-0 left-0 right-0 z-50 px-4 pb-4 pt-3 md:hidden" aria-hidden="true">
        <a href={CTA_URL} data-cta="sticky" class="btn-primary flex items-center justify-center rounded-full px-6 py-4 text-base font-bold">
          Je veux changer ma peau
        </a>
      </div>
    )}

    <!-- ─── FOOTER ────────────────────────────────────────────────────────────── -->
    <footer class="border-t px-6 py-10" style="border-color:oklch(0.91 0.02 65)">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="font-display text-base font-semibold" style="color:oklch(0.22 0.03 40)">Protocole Clear</span>
        <div class="flex flex-wrap justify-center gap-6 text-sm" style="color:oklch(0.5 0.03 45)">
          <a href="mailto:support@protocole-clear.com" class="hover:underline">support@protocole-clear.com</a>
          <a href="/mentions-legales" class="hover:underline">Mentions légales</a>
          <a href="/cgv" class="hover:underline">CGV</a>
          <a href="/confidentialite" class="hover:underline">Confidentialité</a>
        </div>
        <p class="text-sm" style="color:oklch(0.5 0.03 45)">© 2026 Protocole Clear</p>
      </div>
    </footer>

  </body>
</html>

<style>
  /* ─── Photo labels avant/après ─── */
  .photo-label {
    position: absolute;
    bottom: 8px;
    border-radius: 999px;
    padding: 2px 10px;
    font-size: 11px;
    font-weight: 700;
    color: white;
    pointer-events: none;
  }
  .photo-label--avant { left: 8px; background: oklch(0.22 0.03 40 / 0.75); }
  .photo-label--apres { right: 8px; background: oklch(0.66 0.14 45); }

  /* ─── Navbar glassmorphism ─── */
  .navbar {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    background: oklch(0.985 0.012 75 / 0.80);
    border-bottom: 1px solid oklch(0.91 0.02 65 / 0.5);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .navbar.scrolled {
    background: oklch(0.985 0.012 75 / 0.95);
    box-shadow: 0 1px 20px oklch(0.4 0.05 40 / 0.08);
  }

  /* ─── Buttons ─── */
  .btn-primary {
    background: oklch(0.66 0.14 45);
    color: oklch(0.99 0.01 80);
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 20px oklch(0.66 0.14 45 / 0.35);
    white-space: nowrap; /* jamais de flèche orpheline en 2e ligne */
  }
  .btn-primary:hover {
    opacity: 0.92;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px oklch(0.66 0.14 45 / 0.45);
  }
  /* Press feedback tactile (96% du trafic) + focus clavier */
  .btn-primary:active { transform: scale(0.97); }
  a:focus-visible, button:focus-visible, summary:focus-visible {
    outline: 3px solid oklch(0.66 0.14 45);
    outline-offset: 2px;
    border-radius: 9999px;
  }
  a, button, summary { touch-action: manipulation; -webkit-tap-highlight-color: transparent; }

  /* ─── Sélection de texte aux couleurs de la marque ─── */
  ::selection { background: oklch(0.86 0.08 50); color: oklch(0.22 0.03 40); }

  /* ─── Gradient text ─── */
  .text-gradient {
    background: linear-gradient(135deg, oklch(0.70 0.16 50), oklch(0.55 0.14 35));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ─── Hero blobs ─── */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }
  .blob-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, oklch(0.88 0.09 55 / 0.7), transparent 70%);
    top: -10%; left: -10%;
    animation: blob-move-1 18s ease-in-out infinite;
  }
  .blob-2 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, oklch(0.80 0.10 40 / 0.5), transparent 70%);
    top: 20%; right: -5%;
    animation: blob-move-2 22s ease-in-out infinite;
  }
  .blob-3 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, oklch(0.93 0.06 65 / 0.6), transparent 70%);
    bottom: 5%; left: 30%;
    animation: blob-move-3 26s ease-in-out infinite;
  }
  @keyframes blob-move-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(40px, -30px) scale(1.07); }
    66%       { transform: translate(-20px, 40px) scale(0.95); }
  }
  @keyframes blob-move-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(-50px, 30px) scale(1.05); }
    66%       { transform: translate(30px, -40px) scale(0.97); }
  }
  @keyframes blob-move-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(30px, -20px) scale(1.08); }
  }

  /* ─── Hero elements entrance ─── */
  @media (min-width: 768px) {
    .hero-section { min-height: 100dvh; } /* dvh : stable avec la barre d'adresse iOS */
  }
  .hero-section > *:not(.blob) { position: relative; z-index: 1; }

  .hero-badge {
    border-color: oklch(0.86 0.08 50);
    background: oklch(0.93 0.05 55 / 0.8);
    color: oklch(0.58 0.13 40);
    backdrop-filter: blur(8px);
    animation: fade-up 0.7s ease both;
    animation-delay: 0.1s;
  }
  .hero-title  { animation: fade-up 0.8s ease both; animation-delay: 0.25s; }
  .hero-sub    { animation: fade-up 0.8s ease both; animation-delay: 0.4s; }
  .hero-cta    { animation: fade-up 0.8s ease both; animation-delay: 0.55s; }
  .hero-proof  { animation: fade-up 0.8s ease both; animation-delay: 0.7s; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── Proof checkmarks ─── */
  .proof-check { color: oklch(0.66 0.14 45); font-weight: 700; }


  /* ─── Wave dividers ─── */
  .wave-divider { line-height: 0; overflow: hidden; }
  .wave-divider svg { display: block; width: 100%; height: 60px; }

  /* ─── Section labels ─── */
  .section-label {
    display: block;
    position: relative;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 20px; height: 2px;
    background: oklch(0.66 0.14 45);
    vertical-align: middle;
    margin-right: 8px;
  }

  /* ─── Cards hover ─── */
  .method-card {
    background: oklch(0.995 0.006 80);
    box-shadow: 0 1px 2px oklch(0.4 0.05 40 / 0.04), 0 8px 24px oklch(0.4 0.05 40 / 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .method-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px oklch(0.4 0.05 40 / 0.12);
  }
  .method-icon {
    background: oklch(0.93 0.05 55);
    color: oklch(0.58 0.13 40);
  }

  /* ─── Stagger : les cartes d'une grille entrent en cascade (30-80ms/item) ─── */
  [data-reveal] .method-card,
  [data-reveal] .feature-card,
  [data-reveal] .compare-card,
  [data-reveal] .testimonial-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].revealed .method-card,
  [data-reveal].revealed .feature-card,
  [data-reveal].revealed .compare-card,
  [data-reveal].revealed .testimonial-card {
    opacity: 1;
    transform: translateY(0);
  }
  [data-reveal].revealed .method-card:nth-child(2),
  [data-reveal].revealed .compare-card:nth-child(2),
  [data-reveal].revealed .testimonial-card:nth-child(2),
  [data-reveal].revealed .feature-card:nth-child(even) { transition-delay: 0.1s; }
  [data-reveal].revealed .method-card:nth-child(3),
  [data-reveal].revealed .testimonial-card:nth-child(3) { transition-delay: 0.2s; }
  [data-reveal].revealed .feature-card:nth-child(3),
  [data-reveal].revealed .feature-card:nth-child(4) { transition-delay: 0.15s; }
  [data-reveal].revealed .feature-card:nth-child(5),
  [data-reveal].revealed .feature-card:nth-child(6) { transition-delay: 0.25s; }

  .feature-card {
    background: oklch(0.995 0.006 80);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px oklch(0.4 0.05 40 / 0.08);
  }

  .fail-card {
    background: oklch(0.995 0.006 80);
    transition: background 0.2s ease;
  }
  .fail-card:hover { background: oklch(0.99 0.01 75); }

  .testimonial-card {
    background: oklch(0.995 0.006 80);
    box-shadow: 0 1px 2px oklch(0.4 0.05 40 / 0.04), 0 8px 24px oklch(0.4 0.05 40 / 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px oklch(0.4 0.05 40 / 0.12);
  }

  /* ─── Pricing card ─── */
  .pricing-card { background: oklch(0.22 0.03 40); }
  .pricing-glow {
    background: radial-gradient(ellipse 80% 60% at 50% 0%, oklch(0.66 0.14 45 / 0.25), transparent);
  }

  /* ─── FAQ ─── */
  .faq-item { background: oklch(0.995 0.006 80); transition: background 0.2s ease; }
  .faq-item:hover { background: oklch(0.99 0.01 75); }
  .faq-arrow {
    background: oklch(0.93 0.05 55);
    color: oklch(0.58 0.13 40);
  }
  /* Contenu FAQ : fade + slide à l'ouverture (au lieu d'un snap brut) */
  .faq-item[open] > div {
    animation: faq-open 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes faq-open {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── Dark CTA ─── */
  .dark-cta {
    position: relative;
    overflow: hidden;
  }
  .dark-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 50% at 50% 0%, oklch(0.66 0.14 45 / 0.15), transparent);
    pointer-events: none;
  }

  /* ─── Scroll reveal ─── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Photos hero (style polaroïd) ─── */
  .hero-photo {
    border: 5px solid white;
    box-shadow: 0 12px 36px oklch(0.4 0.05 40 / 0.18);
    transition: transform 0.3s ease;
  }
  .photo-tilt-l { transform: rotate(-3deg); }
  .photo-tilt-r { transform: rotate(2.5deg) translateY(8px); }
  @media (hover: hover) {
    .photo-tilt-l:hover { transform: rotate(-1.5deg) scale(1.02); }
    .photo-tilt-r:hover { transform: rotate(1deg) translateY(4px) scale(1.02); }
  }

  /* ─── Pull-quote (la phrase du collègue) ─── */
  .pull-quote {
    border-left: 3px solid oklch(0.66 0.14 45);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 2rem 0;
  }
  .pull-quote p {
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.5rem;
    line-height: 1.35;
    font-weight: 600;
    font-style: italic;
    color: oklch(0.28 0.05 40);
  }

  /* ─── Numéros fantômes (cartes méthode) ─── */
  .ghost-num {
    position: absolute;
    top: -0.12em;
    right: 0.04em;
    font-size: 6.5rem;
    font-weight: 700;
    line-height: 1;
    color: oklch(0.66 0.14 45 / 0.08);
    pointer-events: none;
    user-select: none;
  }

  /* ─── Pull quote (storytelling) ─── */
  .pull-quote {
    border-left: 3px solid oklch(0.66 0.14 45);
    padding: 12px 20px;
    margin: 4px 0;
    border-radius: 0 12px 12px 0;
    background: oklch(0.86 0.08 50 / 0.25);
  }
  .pull-quote p {
    font-style: italic;
    color: oklch(0.38 0.04 40);
    font-size: 1.05rem;
  }

  /* ─── Eyebrow (label de section) ─── */
  .eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: oklch(0.66 0.14 45);
    margin-bottom: 14px;
  }

  /* ─── Final sombre : halo orangé comme la pricing card ─── */
  .final-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 75% 55% at 50% 0%, oklch(0.66 0.14 45 / 0.18), transparent);
    pointer-events: none;
  }

  /* ─── Façade VSL (miniature avant/après + play, le player charge au tap) ─── */
  .vsl-facade {
    cursor: pointer;
    box-shadow: 0 8px 32px oklch(0.4 0.05 40 / 0.15);
    transition: transform 0.25s ease;
  }
  .vsl-facade:active { transform: scale(0.985); }
  .vsl-facade:focus-visible { outline: 3px solid oklch(0.66 0.14 45); outline-offset: 3px; }
  .vsl-overlay {
    background: oklch(0.22 0.03 40 / 0.28);
    transition: background 0.2s ease;
  }
  @media (hover: hover) {
    .vsl-facade:hover .vsl-overlay { background: oklch(0.22 0.03 40 / 0.38); }
  }
  .vsl-play {
    width: 72px;
    height: 72px;
    background: oklch(0.66 0.14 45);
    color: oklch(0.99 0.01 80);
    box-shadow: 0 8px 30px oklch(0.66 0.14 45 / 0.55);
    animation: play-pulse 2.2s ease-in-out infinite;
  }
  .vsl-play svg { margin-left: 3px; }
  @keyframes play-pulse {
    0%, 100% { transform: scale(1); }
    50%      { transform: scale(1.08); }
  }

  /* ─── Carte coach ─── */
  .coach-card {
    box-shadow: 0 1px 2px oklch(0.4 0.05 40 / 0.04), 0 8px 24px oklch(0.4 0.05 40 / 0.06);
  }

  /* ─── Comparatif deux portes ─── */
  .compare-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .compare-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 36px oklch(0.4 0.05 40 / 0.10);
  }

  /* ─── Sticky CTA mobile (safe-area iPhone : barre home) ─── */
  .sticky-cta {
    background: linear-gradient(to top, oklch(0.985 0.012 75) 60%, transparent);
    transform: translateY(120%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    padding-bottom: calc(1rem + env(safe-area-inset-bottom));
  }
  .sticky-cta.visible {
    transform: translateY(0);
    pointer-events: auto;
  }
  .sticky-cta a { box-shadow: 0 8px 30px oklch(0.66 0.14 45 / 0.45); }

  /* ─── Perf mobile : blobs allégés (96% du trafic est mobile) ─── */
  @media (max-width: 768px) {
    .blob { filter: blur(40px); opacity: 0.4; }
    .blob-1 { width: 380px; height: 380px; }
    .blob-2 { width: 320px; height: 320px; }
    .blob-3 { display: none; }
  }

  /* ─── Accessibilité : respect du reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .blob, .hero-title, .hero-sub, .hero-proof, .vsl-play {
      animation: none !important;
    }
    [data-reveal] { opacity: 1; transform: none; transition: none; }
    [data-reveal] .method-card, [data-reveal] .feature-card,
    [data-reveal] .compare-card, [data-reveal] .testimonial-card {
      opacity: 1; transform: none; transition: none;
    }
    .sticky-cta { transition: none; }
    .faq-item[open] > div { animation: none; }
  }
</style>

<script>
  import { track } from '@vercel/analytics';

  // ─── Navbar scroll effect
  const navbar = document.querySelector('.navbar') as HTMLElement;
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // ─── Tracking : clics CTA (position identifiée par data-cta)
  document.querySelectorAll<HTMLAnchorElement>('[data-cta]').forEach((el) => {
    el.addEventListener('click', () => {
      track('cta_click', { position: el.dataset.cta ?? 'unknown' });
    });
  });

  // ─── Tracking : profondeur de scroll (paliers uniques)
  const scrollMarks = new Set<number>();
  window.addEventListener('scroll', () => {
    const depth = (window.scrollY + window.innerHeight) / document.body.scrollHeight;
    for (const mark of [25, 50, 75, 100]) {
      if (depth * 100 >= mark && !scrollMarks.has(mark)) {
        scrollMarks.add(mark);
        track('scroll_depth', { percent: mark });
      }
    }
  }, { passive: true });

  // ─── Tracking : ouverture des questions FAQ
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach((d) => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        const q = d.querySelector('summary')?.textContent?.trim().slice(0, 80) ?? '';
        track('faq_open', { question: q });
      }
    });
  });

  // ─── Sticky CTA mobile : après ~2,5 écrans, masqué si un CTA inline est déjà visible
  const stickyBar = document.getElementById('sticky-cta');
  if (stickyBar) {
    const visibleCtas = new Set<Element>();
    const updateSticky = () => {
      const show = window.scrollY > window.innerHeight * 2.5 && visibleCtas.size === 0;
      stickyBar.classList.toggle('visible', show);
      stickyBar.setAttribute('aria-hidden', String(!show));
    };
    const inlineCtas = document.querySelectorAll('[data-cta="mid-page"], [data-cta="final"]');
    const ctaObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => { e.isIntersecting ? visibleCtas.add(e.target) : visibleCtas.delete(e.target); });
      updateSticky();
    }, { rootMargin: '0px 0px -60px 0px' });
    inlineCtas.forEach((el) => ctaObserver.observe(el));
    window.addEventListener('scroll', updateSticky, { passive: true });
  }

  // ─── VSL Bunny Stream : tracking via postMessage (play/pause/ended + % regardé)
  const vslMarks = new Set<number>();
  window.addEventListener('message', (e) => {
    if (!String(e.origin).includes('mediadelivery.net')) return;
    const data = (e.data || {}) as { event?: string; currentTime?: number; duration?: number };
    if (data.event === 'play') track('vsl_play');
    if (data.event === 'pause') track('vsl_pause');
    if (data.event === 'ended') { track('vsl_ended'); vslMarks.add(100); }
    if (data.event === 'timeupdate' && data.currentTime && data.duration) {
      const pct = (data.currentTime / data.duration) * 100;
      for (const mark of [25, 50, 75]) {
        if (pct >= mark && !vslMarks.has(mark)) {
          vslMarks.add(mark);
          track('vsl_watched', { percent: mark });
        }
      }
    }
  });

  // ─── Sections vues : savoir quelles sections l'utilisateur a réellement atteintes
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const section = (entry.target as HTMLElement).dataset.section;
        if (section) {
          track('section_viewed', { section });
          sectionObserver.unobserve(entry.target);
        }
      }
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('[data-section]').forEach((el) => sectionObserver.observe(el));

  // ─── Scroll reveal (sections 3+ only)
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

  // ─── Compteur de places réel (capacité mensuelle − paiements Stripe du mois)
  // En cas d'échec du fetch, le texte fallback honnête reste affiché.
  fetch('https://app.protocole-clear.com/api/public/places')
    .then((r) => (r.ok ? r.json() : null))
    .then((data) => {
      if (!data || typeof data.places !== 'number' || data.places <= 0) return;
      const txt = `${data.places} place${data.places > 1 ? 's' : ''} restante${data.places > 1 ? 's' : ''} ce mois-ci`;
      document.querySelectorAll('.js-places').forEach((el) => {
        el.textContent = `${txt} · Suivi individuel`;
      });
      document.querySelectorAll('.js-places-inline').forEach((el) => {
        el.textContent = txt;
      });
    })
    .catch(() => {});
</script>
