---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

const PRICE = "97";
const PRICE_ORIGINAL = "197";
const CTA_URL = "https://buy.stripe.com/4gM6oz5c28Rq35x5Wybsc00";

// EDIT: mets ton vrai compte Instagram (canal DM pour les hésitants)
const INSTAGRAM_URL = "https://instagram.com/TON_COMPTE";

// EDIT: URL de ta VSL (fichier .mp4 hébergé — Bunny, R2, ou /vsl.mp4 dans public/).
// Tant que c'est vide, le hero affiche les photos avant/après seules.
// Quand tu la remplis, les photos deviennent la miniature cliquable de la vidéo.
const VSL_URL = "";

// Barre CTA sticky mobile en bas d'écran. Désactivée : redondante avec le CTA
// navbar toujours visible. Repasse à true si les données montrent qu'elle manque.
const STICKY_CTA = false;

// ── Témoignages ──────────────────────────────────────────────────────────────
// Passe à `true` quand tu as remplacé les placeholders par de vrais retours.
// N'active JAMAIS avec des témoignages fictifs (risque légal + confiance).
const SHOW_TESTIMONIALS = false;
const TESTIMONIALS = [
  {
    quote: "[Remplace par un vrai retour — idéalement 2-3 phrases concrètes : situation de départ, ce qui a changé, comment elle/il se sent maintenant.]",
    name: "[Prénom]",
    age: "[24 ans]",
    profile: "Peau grasse · Acné modérée",
    duration: "8 semaines de protocole",
  },
  {
    quote: "[Vrai retour élève #2]",
    name: "[Prénom]",
    age: "[19 ans]",
    profile: "Peau mixte · Comédons",
    duration: "6 semaines de protocole",
  },
  {
    quote: "[Vrai retour élève #3]",
    name: "[Prénom]",
    age: "[28 ans]",
    profile: "Peau sensible · Marques post-acné",
    duration: "90 jours de protocole",
  },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Le premier protocole acné entièrement personnalisé, suivi par un coach pendant 90 jours. Fini les produits au hasard." />
    <title>Protocole Clear — Ta peau nette en 90 jours</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <!-- Open Graph (aperçus WhatsApp / Instagram / Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://protocole-clear.com/" />
    <meta property="og:title" content="Protocole Clear — Ta peau nette en 90 jours" />
    <meta property="og:description" content="Un protocole acné construit pour ta peau, suivi par un coach pendant 90 jours. Bilan peau + routine sur mesure + ajustements inclus." />
    <meta property="og:image" content="https://protocole-clear.com/icon-512.png" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Protocole Clear" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Protocole Clear — Ta peau nette en 90 jours" />
    <meta name="twitter:description" content="Un protocole acné construit pour ta peau, suivi par un coach pendant 90 jours." />
    <meta name="twitter:image" content="https://protocole-clear.com/icon-512.png" />

    <!-- Microsoft Clarity — heatmaps de scroll + session replays -->
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x5kf9doj5x");
    </script>
  </head>

  <body>

    <!-- ─── NAVBAR ──────────────────────────────────────────────────────────── -->
    <nav class="navbar fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 py-4">
      <div class="flex items-center gap-2.5">
        <img src="/logo_clear.png" alt="Protocole Clear" width="64" height="64" style="border-radius:50%;" />
        <span class="hidden sm:inline font-display text-lg font-semibold tracking-tight" style="color:oklch(0.22 0.03 40)">
          Protocole Clear
        </span>
      </div>
      <a href={CTA_URL} data-cta="navbar" class="btn-primary flex min-h-11 items-center rounded-full px-5 text-sm font-semibold">
        Commencer →
      </a>
    </nav>

    <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
    <section class="hero-section relative min-h-screen flex flex-col items-center px-6 pt-32 pb-12 text-center overflow-hidden">

      <!-- Animated blobs -->
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>

      <!-- Contenu centré verticalement dans l'espace disponible -->
      <div class="flex-1 flex flex-col items-center justify-center w-full">

        <!-- Headline -->
        <h1 class="hero-title text-balance max-w-3xl text-[2.25rem] font-bold leading-[1.12] sm:text-5xl md:text-7xl mb-6">
          Tu as tout essayé.<br />
          <span class="text-gradient">L'acné est <br class="sm:hidden" />toujours là.</span>
        </h1>

        <!-- Subheadline -->
        <p class="hero-sub max-w-xl text-lg leading-relaxed mb-8" style="color:oklch(0.5 0.03 45)">
          Un protocole acné construit pour <em>ta</em> peau, suivi par un coach semaine après semaine.
          Objectif&nbsp;: <strong style="color:oklch(0.32 0.03 40)">une peau que tu reconnais, en 90 jours.</strong>
        </p>

        <!-- Preuve visuelle — VSL si disponible, sinon photos avant/après -->
        <div class="hero-proof w-full max-w-md mx-auto">
          {VSL_URL ? (
            <>
              <div id="vsl-facade" class="vsl-facade relative overflow-hidden rounded-3xl" role="button" tabindex="0"
                aria-label="Lire la vidéo : mon histoire et le protocole en 2 minutes">
                <div class="grid grid-cols-2">
                  <div class="relative">
                    <img src="/avant.jpg" class="w-full aspect-[3/4] object-cover" alt="Ma peau avant le protocole" fetchpriority="high" />
                    <div class="absolute bottom-3 left-3 rounded-full px-3 py-1 text-xs font-bold"
                      style="background:oklch(0.22 0.03 40 / 0.75);color:white">Avant</div>
                  </div>
                  <div class="relative">
                    <img src="/apres.jpg" class="w-full aspect-[3/4] object-cover" alt="Ma peau après 90 jours de protocole" fetchpriority="high" />
                    <div class="absolute bottom-3 right-3 rounded-full px-3 py-1 text-xs font-bold"
                      style="background:oklch(0.66 0.14 45);color:white">Après</div>
                  </div>
                </div>
                <div class="vsl-overlay absolute inset-0 flex flex-col items-center justify-center gap-4">
                  <span class="vsl-play flex items-center justify-center rounded-full" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                  <span class="rounded-full px-4 py-1.5 text-sm font-bold"
                    style="background:oklch(0.22 0.03 40 / 0.8);color:white">Mon histoire en 2 minutes</span>
                </div>
              </div>
              <video id="vsl-player" class="hidden w-full rounded-3xl" src={VSL_URL} controls playsinline preload="none"></video>
            </>
          ) : (
            <div class="grid grid-cols-2 gap-2 px-2">
              <div class="hero-photo photo-tilt-l relative overflow-hidden rounded-2xl aspect-[3/4]" style="background:oklch(0.93 0.05 55)">
                <img src="/avant.jpg" class="w-full h-full object-cover" alt="Ma peau avant le protocole" fetchpriority="high" />
                <div class="absolute bottom-3 left-3 rounded-full px-3 py-1 text-xs font-bold"
                  style="background:oklch(0.22 0.03 40 / 0.75);color:white">Avant</div>
              </div>
              <div class="hero-photo photo-tilt-r relative overflow-hidden rounded-2xl aspect-[3/4]" style="background:oklch(0.93 0.05 55)">
                <img src="/apres.jpg" class="w-full h-full object-cover" alt="Ma peau après 90 jours de protocole" fetchpriority="high" />
                <div class="absolute bottom-3 left-3 rounded-full px-3 py-1 text-xs font-bold"
                  style="background:oklch(0.66 0.14 45);color:white">Après</div>
              </div>
            </div>
          )}
          <p class="text-xs mt-3" style="color:oklch(0.55 0.03 50)">
            Ma peau, après 90 jours du protocole. Sans filtre ni retouche.
          </p>
        </div>

      </div>

      <!-- Scroll indicator — toujours en bas -->
      <div class="scroll-indicator flex flex-col items-center gap-2">
        <span class="text-xs uppercase tracking-widest" style="color:oklch(0.7 0.03 60)">Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- ─── BANDE BÉNÉFICES (compacte, sous le hero) ─────────────────────────── -->
    <section class="px-6 pb-14" data-reveal>
      <div class="max-w-3xl mx-auto grid grid-cols-1 gap-4 sm:grid-cols-2">
        {[
          { title: "Bilan peau personnalisé", desc: "Questionnaire complet + analyse de tes photos par le coach" },
          { title: "Routine sur mesure", desc: "Produits AM/PM sélectionnés pour ton profil exact, avec instructions" },
          { title: "Suivi coach 90 jours", desc: "Métriques hebdomadaires + ajustements de routine inclus" },
          { title: "WhatsApp privé", desc: "Accès direct à Mehdi pour toutes tes questions" },
        ].map((b) => (
          <div class="flex items-start gap-3 rounded-2xl border p-4" style="border-color:oklch(0.91 0.02 65);background:oklch(0.995 0.006 80)">
            <span class="proof-check mt-0.5 shrink-0">✓</span>
            <div>
              <p class="text-sm font-semibold" style="color:oklch(0.22 0.03 40)">{b.title}</p>
              <p class="text-xs mt-0.5 leading-snug" style="color:oklch(0.55 0.03 50)">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── WAVE 1 ────────────────────────────────────────────────────────────── -->
    <div class="wave-divider" style="background:oklch(0.985 0.012 75)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="oklch(0.965 0.025 75)" />
      </svg>
    </div>

    <!-- ─── HOOK : HISTOIRE (no reveal — 2ème bloc visible) ─────────────────── -->
    <section style="background:oklch(0.965 0.025 75)" class="px-6 py-16">
      <div class="max-w-2xl mx-auto">
        <div class="space-y-6 text-lg leading-relaxed" style="color:oklch(0.32 0.03 40)">
          <p>La photo de gauche, là-haut&nbsp;? <strong>C'est moi.</strong></p>
          <p>Il y a <strong>5 ans</strong>, j'avais une peau que je ne reconnaissais plus.</p>
          <p>Des boutons. Des marques. Des cicatrices rouges qui ne partaient pas.</p>
          <p>
            Je refusais qu'on me prenne en photo.<br />
            Je regardais en bas quand je parlais aux gens.<br />
            J'annulais des sorties avec mes amis et mes proches.
          </p>
          <p>Ce qui me tuait intérieurement, c'était pas juste les boutons.</p>
          <p>C'était le regard des autres.<br />Ou plutôt, le regard que j'imaginais qu'ils posaient sur moi.</p>
          <p><strong>Alors j'ai cherché. J'ai tout essayé... produits, traitements, routines.</strong></p>
          <p>Des centaines d'euros engloutis. Des mois à attendre des résultats qui ne venaient pas.</p>
          <p>Jusqu'au jour où, au travail, un collègue m'a regardé et m'a lâché :</p>
          <blockquote class="pull-quote">
            <p>« Mon pauvre, je sais pas comment tu es sorti de chez toi avec un visage pareil… »</p>
          </blockquote>
          <p>J'étais désemparé.</p>
          <p>Un soir, je me retrouve là, face au miroir, à regarder ma peau.</p>
          <p>Et je me dis : <em>c'est ça pour toujours ?</em></p>
        </div>
      </div>
    </section>

    <!-- ─── PIVOT — conclusion du bloc histoire ──────────────────────────────── -->
    <section class="px-6 pb-16" style="background:oklch(0.965 0.025 75)" data-reveal>
      <div class="max-w-2xl mx-auto">
        <div class="rounded-3xl p-8 text-center" style="background:oklch(0.86 0.08 50)">
          <p class="text-xl font-semibold leading-snug" style="color:oklch(0.32 0.08 40)">
            Le problème, c'est pas les produits.<br />
            C'est qu'ils sont faits pour <em>tout le monde</em>.<br />
            Et toi, t'es pas tout le monde.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── LE DÉCLIC — suite directe, même fond crème ───────────────────────── -->
    <section class="px-6 pb-16" style="background:oklch(0.965 0.025 75)" data-reveal>
      <div class="max-w-2xl mx-auto">
        <div class="space-y-6 text-lg leading-relaxed" style="color:oklch(0.32 0.03 40)">
          <p>Ce jour-là, j'ai arrêté de chercher <strong>LE produit miracle</strong>.</p>
          <p>J'ai commencé à construire <strong>UN protocole</strong>.</p>
          <p>Pas une liste d'ingrédients au hasard. Pas une routine Tiktok.</p>
          <p>Un système. Adapté à <em>mon</em> type de peau, <em>mes</em> déclencheurs, <em>mes</em> habitudes.</p>
          <p>
            J'ai appris à lire les INCI. À comprendre pourquoi certains produits irritaient ma barrière cutanée.
            À ajuster semaine après semaine ce qui fonctionnait ou pas.
          </p>
          <p>
            Et pour la première fois en <strong>5 ans</strong>, j'ai regardé mon visage dans le miroir sans détourner les yeux.
          </p>
          <p>C'est ça, le protocole que j'ai codifié pour toi.</p>
        </div>
      </div>
    </section>

    <!-- ─── QUI JE SUIS ──────────────────────────────────────────────────────── -->
    <section class="px-6 pb-16" style="background:oklch(0.965 0.025 75)" data-reveal>
      <div class="max-w-2xl mx-auto">
        <div class="coach-card flex flex-col sm:flex-row items-center gap-6 rounded-3xl p-7" style="background:oklch(0.995 0.006 80)">
          <img src="/mehdi.jpg" alt="Mehdi, fondateur de Protocole Clear"
            class="h-28 w-28 shrink-0 rounded-full object-cover"
            style="border:3px solid oklch(0.86 0.08 50)" loading="lazy" />
          <div class="text-center sm:text-left">
            <p class="font-display text-xl font-semibold mb-1" style="color:oklch(0.22 0.03 40)">Moi, c'est Mehdi.</p>
            <p class="text-sm leading-relaxed" style="color:oklch(0.5 0.03 45)">
              J'ai 27 ans, et je souffrais d'acné depuis 10 ans. 10 ans à me battre contre mes boutons, des centaines d'heures à étudier les compositions des produits et la barrière cutanée.
              Aujourd'hui, j'ai enfin gagné le combat. Je crée du contenu sur la skincare et comment traiter son acné, et je suis chaque élève personnellement jusqu'à amélioration de leur peau.
            </p>
          </div>
        </div>

        <!-- CTA intégré au flux — même fond, pas de rupture visuelle -->
        <div class="mt-10 text-center">
          <a href={CTA_URL} data-cta="mi-page" class="btn-primary inline-block rounded-full px-7 py-4 text-base font-bold">
            Je veux ma routine sur mesure →
          </a>
          <p class="text-xs mt-3" style="color:oklch(0.55 0.03 50)">
            Paiement unique de {PRICE}€ · Bilan peau prêt en 48h max · Garantie résultat 90 jours
          </p>
        </div>
      </div>
    </section>

    <!-- ─── TÉMOIGNAGES (îlot blanc complet : vague + section + vague) ───────── -->
    {SHOW_TESTIMONIALS && (
      <div class="wave-divider" style="background:oklch(0.965 0.025 75)">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0,15 C480,60 960,0 1440,45 L1440,60 L0,60 Z" fill="oklch(0.985 0.012 75)" />
        </svg>
      </div>
    )}
    {SHOW_TESTIMONIALS && (
      <section class="py-16 px-6" data-reveal>
        <div class="max-w-5xl mx-auto">
          <h2 class="text-3xl font-bold text-center mb-4 md:text-4xl" style="color:oklch(0.22 0.03 40)">
            Ils ont suivi le protocole.
          </h2>
          <p class="text-center text-lg mb-12" style="color:oklch(0.5 0.03 45)">
            Des retours d'élèves, avec leur profil peau et leur durée de suivi.
          </p>

          <!-- Mobile : carrousel scroll-snap · Desktop : grille 3 colonnes -->
          <div class="testimonial-track flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory md:grid md:grid-cols-3 md:gap-6 md:overflow-visible md:pb-0">
            {TESTIMONIALS.map((t) => (
              <figure class="testimonial-card snap-center shrink-0 w-[85%] sm:w-[70%] md:w-auto rounded-3xl p-7 flex flex-col gap-5">
                <span class="text-4xl leading-none font-display" style="color:oklch(0.66 0.14 45)" aria-hidden="true">“</span>
                <blockquote class="text-base leading-relaxed flex-1" style="color:oklch(0.32 0.03 40)">
                  {t.quote}
                </blockquote>
                <figcaption class="flex items-center gap-3 pt-2 border-t" style="border-color:oklch(0.93 0.02 65)">
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold"
                    style="background:oklch(0.93 0.05 55);color:oklch(0.58 0.13 40)">
                    {t.name.replace(/[[\]]/g, "").charAt(0)}
                  </span>
                  <span class="min-w-0">
                    <span class="block text-sm font-semibold" style="color:oklch(0.22 0.03 40)">{t.name} · {t.age}</span>
                    <span class="block text-xs mt-0.5" style="color:oklch(0.55 0.03 50)">{t.profile} · {t.duration}</span>
                  </span>
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    {SHOW_TESTIMONIALS && (
      <div class="wave-divider" style="background:oklch(0.985 0.012 75)">
        <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="oklch(0.965 0.025 75)" />
        </svg>
      </div>
    )}

    <!-- ─── LA MÉTHODE ───────────────────────────────────────────────────────── -->
    <section class="pt-8 pb-16 px-6 md:py-16" style="background:oklch(0.965 0.025 75)" data-reveal>
      <div class="max-w-4xl mx-auto">
        <p class="eyebrow text-center">La méthode</p>
        <h2 class="text-3xl font-bold text-center mb-4 md:text-5xl text-balance" style="color:oklch(0.22 0.03 40)">
          Protocole Clear, c'est pas une routine.<br />
          <span class="text-gradient">C'est un système.</span>
        </h2>
        <p class="text-center text-lg max-w-xl mx-auto mb-16" style="color:oklch(0.5 0.03 45)">
          Construit autour de ton profil peau unique, ajusté chaque semaine par un coach.
        </p>

        <div class="grid gap-6 md:grid-cols-3">
          {[
            { num: "01", title: "Bilan peau", desc: "Tu remplis ton bilan complet : type de peau, types d'acné, intensité, routine actuelle, objectif. Tu envoies tes photos. Le coach analyse et construit ta routine sur mesure.",
              icon: "M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9 2 2 4-4" },
            { num: "02", title: "Routine sur mesure", desc: "Le coach sélectionne les produits adaptés à ton profil exact dans l'application. Routine matin et soir, ordre d'application, instructions précises. Analyseur INCI inclus.",
              icon: "M12 2.7 6.3 8.4a8 8 0 1 0 11.4 0L12 2.7Z" },
            { num: "03", title: "Suivi 90 jours", desc: "Chaque semaine, tu notes tes métriques. Le coach analyse l'évolution et ajuste la routine si nécessaire.",
              icon: "m22 7-8.5 8.5-5-5L2 17M16 7h6v6" },
          ].map((p) => (
            <div class="method-card relative overflow-hidden rounded-3xl p-8 flex flex-col gap-4">
              <span class="ghost-num font-display" aria-hidden="true">{p.num}</span>
              <span class="method-icon flex h-11 w-11 items-center justify-center rounded-2xl" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={p.icon} />
                </svg>
              </span>
              <h3 class="text-xl font-bold" style="color:oklch(0.22 0.03 40)">{p.title}</h3>
              <p class="text-sm leading-relaxed" style="color:oklch(0.5 0.03 45)">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── WAVE 4 ────────────────────────────────────────────────────────────── -->
    <div class="wave-divider" style="background:oklch(0.965 0.025 75)">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,45 C360,0 1080,60 1440,15 L1440,60 L0,60 Z" fill="oklch(0.985 0.012 75)" />
      </svg>
    </div>

    <!-- ─── CE QUE TU REÇOIS ─────────────────────────────────────────────────── -->
    <section class="max-w-4xl mx-auto px-6 py-16" data-reveal>
      <p class="eyebrow text-center">L'offre</p>
      <h2 class="text-3xl font-bold text-center mb-16 md:text-5xl" style="color:oklch(0.22 0.03 40)">
        Tout ce dont tu as besoin.<br />Rien de superflu.
      </h2>

      <div class="grid gap-4 md:grid-cols-2 mb-16">
        {[
          ["Application web privée", "Accès à vie à ton espace personnel avec des outils pour soutenir ton protocole"],
          ["Bilan peau initial", "Formulaire complet + analyse de tes photos par le coach"],
          ["Routine matin/soir sur mesure", "Produits sélectionnés pour ton profil exact, avec instructions précises"],
          ["Analyseur INCI", "Scanne n'importe quel produit et sache instantanément s'il est adapté à ta peau"],
          ["Suivi hebdomadaire coach", "90 jours de suivi avec métriques, photos de progression et ajustements"],
          ["Ajustements de routine inclus", "Si quelque chose ne marche pas, la routine est adaptée. Pas de frais supplémentaires."],
        ].map(([title, desc]) => (
          <div class="feature-card flex gap-4 rounded-2xl border p-5" style="border-color:oklch(0.91 0.02 65)">
            <span class="mt-0.5 text-lg" style="color:oklch(0.66 0.14 45)">✓</span>
            <div>
