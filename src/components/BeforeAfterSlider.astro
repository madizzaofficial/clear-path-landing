---
interface Props {
  beforeSrc: string;
  afterSrc: string;
  beforeAlt?: string;
  afterAlt?: string;
  initialPosition?: number; // 0-100, default 45
}

const {
  beforeSrc,
  afterSrc,
  beforeAlt = "Avant",
  afterAlt = "Après",
  initialPosition = 45,
} = Astro.props;
---

<div class="ba-slider" role="img" aria-label="Comparaison avant/après">
  <div class="ba-images">
    <!-- Image AVANT (fond) -->
    <img src={beforeSrc} alt={beforeAlt} class="ba-img ba-before" draggable="false" />
    <!-- Image APRÈS (révélée par clip-path depuis la droite) -->
    <img src={afterSrc} alt={afterAlt} class="ba-img ba-after" draggable="false"
      style={`clip-path: inset(0 0 0 ${initialPosition}%)`} />
  </div>

  <!-- Labels -->
  <span class="ba-label ba-label-left">Avant</span>
  <span class="ba-label ba-label-right">Après</span>

  <!-- Handle -->
  <div class="ba-handle" style={`left: ${initialPosition}%`} role="slider"
    aria-label="Faites glisser pour comparer" aria-valuenow={initialPosition}
    aria-valuemin={0} aria-valuemax={100} tabindex="0">
    <div class="ba-line"></div>
    <div class="ba-circle">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M7 5L2 10L7 15" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M13 5L18 10L13 15" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
</div>

<style>
  .ba-slider {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    border-radius: 1.5rem;
    overflow: hidden;
    cursor: col-resize;
    user-select: none;
    -webkit-user-select: none;
    box-shadow: 0 8px 40px oklch(0.4 0.05 40 / 0.15);
  }

  .ba-images {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
  }

  .ba-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    pointer-events: none;
  }

  .ba-after {
    transition: clip-path 0.02s linear;
  }

  .ba-label {
    position: absolute;
    bottom: 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 0.9rem;
    border-radius: 9999px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 3;
  }

  .ba-label-left {
    left: 1rem;
    background: oklch(0.22 0.03 40 / 0.80);
    color: white;
  }

  .ba-label-right {
    right: 1rem;
    background: oklch(0.66 0.14 45);
    color: white;
  }

  .ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .ba-line {
    width: 2px;
    flex: 1;
    background: white;
    box-shadow: 0 0 6px oklch(0 0 0 / 0.3);
  }

  .ba-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: oklch(0.66 0.14 45);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px oklch(0.4 0.05 40 / 0.35);
    touch-action: none;
    pointer-events: all;
    cursor: col-resize;
  }

  .ba-handle:focus-visible .ba-circle {
    outline: 3px solid oklch(0.66 0.14 45);
    outline-offset: 3px;
  }
</style>

<script>
  const slider = document.querySelector('.ba-slider') as HTMLElement;
  const after = slider?.querySelector('.ba-after') as HTMLImageElement;
  const handle = slider?.querySelector('.ba-handle') as HTMLElement;

  if (slider && after && handle) {
    let dragging = false;

    function setPosition(clientX: number) {
      const rect = slider.getBoundingClientRect();
      const pct = Math.min(100, Math.max(0, ((clientX - rect.left) / rect.width) * 100));
      after.style.clipPath = `inset(0 0 0 ${pct.toFixed(2)}%)`;
      handle.style.left = `${pct.toFixed(2)}%`;
      handle.setAttribute('aria-valuenow', String(Math.round(pct)));
    }

    // Mouse
    slider.addEventListener('mousedown', (e) => { dragging = true; setPosition(e.clientX); });
    window.addEventListener('mousemove', (e) => { if (dragging) setPosition(e.clientX); });
    window.addEventListener('mouseup', () => { dragging = false; });

    // Touch
    slider.addEventListener('touchstart', (e) => {
      dragging = true;
      setPosition(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener('touchmove', (e) => {
      if (dragging) setPosition(e.touches[0].clientX);
    }, { passive: true });
    window.addEventListener('touchend', () => { dragging = false; });

    // Keyboard (arrow keys)
    handle.addEventListener('keydown', (e) => {
      const rect = slider.getBoundingClientRect();
      const curr = parseFloat(handle.style.left);
      if (e.key === 'ArrowLeft') setPosition(rect.left + (curr - 5) / 100 * rect.width);
      if (e.key === 'ArrowRight') setPosition(rect.left + (curr + 5) / 100 * rect.width);
    });
  }
</script>
